        "description": "Reach the deliberately invalid negative-gold state.",
        "condition": {
          "left": { "variable": "gold" },
          "operator": "<",
          "right": { "literal": 0 }
        }
      },
      "assertions": [
        {
          "id": "gold_nonnegative",
          "description": "Gold must never be negative.",
          "when": "always",
          "condition": {
